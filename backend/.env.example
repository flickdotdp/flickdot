# ==============================================================================
# 🚀 LOCAL AI IMAGE GENERATION PLATFORM - BACKEND CONFIGURATION
# ==============================================================================
# Copy this file to '.env' in the backend directory.
# FastAPI will automatically load these settings on startup via `config.py`.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🌐 FASTAPI CORE SETTINGS
# ------------------------------------------------------------------------------
# The name of the API.
API_TITLE="AI Image Generator API"

# API Version.
API_VERSION="1.0.0"

# Set to "production" to disable Swagger UI and reduce debug logging.
# Default: development
ENVIRONMENT="development"

# Comma-separated list of allowed origins for CORS.
# Default: http://localhost:4000,http://127.0.0.1:4000 (Next.js default ports)
CORS_ORIGINS="http://localhost:4000,http://127.0.0.1:4000"

# ------------------------------------------------------------------------------
# 🗄️ DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# The SQLAlchemy database URL.
# For local deployment, SQLite is highly recommended and requires zero setup.
# Format: sqlite:///./data/database.db
DATABASE_URL="sqlite:///./data/ai_platform.db"

# ------------------------------------------------------------------------------
# 🤖 COMFYUI ENGINE INTEGRATION
# ------------------------------------------------------------------------------
# The fully qualified URL where your local ComfyUI instance is running.
# Default: http://127.0.0.1:8188
COMFYUI_SERVER_URL="http://127.0.0.1:8188"

# Maximum time (in seconds) to wait for ComfyUI to respond to an API request.
# Note: This is for the request itself, not the total generation time.
COMFYUI_TIMEOUT_SECONDS=60

# ------------------------------------------------------------------------------
# ⚙️ GENERATION WORKER & QUEUE SETTINGS
# ------------------------------------------------------------------------------
# How often (in seconds) the background worker checks the database for "queued" jobs.
# Lower = faster response, but higher CPU usage.
# Default: 1.0
WORKER_POLL_INTERVAL=1.0

# How many image generations to process simultaneously.
# CAUTION: Setting this > 1 requires a GPU with significant VRAM (e.g., 24GB+).
# Default: 1
WORKER_CONCURRENCY=1

# How many minutes a job can be stuck in "processing" before the worker assumes 
# ComfyUI crashed and marks it as "failed".
WORKER_STALE_JOB_TIMEOUT_MINUTES=15

# ------------------------------------------------------------------------------
# 📁 STORAGE & ASSET PATHS
# ------------------------------------------------------------------------------
# Base directory where all user assets and generated images are saved.
# It is highly recommended to use an absolute path for production.
# Default: ./storage
STORAGE_DIR="./storage"

# Subdirectories (relative to STORAGE_DIR)
# Where user-uploaded source images are kept
UPLOAD_DIR="uploads"

# Where finished generations are saved
OUTPUT_DIR="outputs"

# Where optimized thumbnails are saved for the gallery
THUMBNAIL_DIR="thumbnails"

# Where JSON workflow templates are stored
WORKFLOW_DIR="workflows"

# ------------------------------------------------------------------------------
# 🔒 SECURITY & AUTHENTICATION (For Future Expansion)
# ------------------------------------------------------------------------------
# Currently, the platform runs in a pure local, single-user mode.
# Setting these will prepare the system for multi-user cloud deployment.

# JWT Secret Key for signing user tokens
# SECRET_KEY="generate_a_secure_random_string_here"

# JWT Expiration Time (in minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# 📡 CLOUD SYNCHRONIZATION & TELEMETRY (For Future Expansion)
# ------------------------------------------------------------------------------
# Enable syncing local generations to an S3-compatible cloud bucket.
# ENABLE_CLOUD_SYNC=false
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET_NAME=""
