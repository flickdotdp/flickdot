# ==============================================================================
# 🚀 LOCAL AI IMAGE GENERATION PLATFORM - FRONTEND CONFIGURATION
# ==============================================================================
# Copy this file to '.env.local' and adjust values for your environment.
# Note: Variables prefixed with 'NEXT_PUBLIC_' are exposed to the browser.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🌐 CORE NETWORK CONFIGURATION
# ------------------------------------------------------------------------------
# The base URL of the FastAPI backend. 
# For local dev, Next.js rewrites in next.config.ts handle CORS, but this acts as the fallback.
# Default: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# The fully qualified WebSocket endpoint of the FastAPI backend.
# The UI will attempt to establish a persistent connection here on startup.
# Default: ws://127.0.0.1:8000/api/v1/ws
NEXT_PUBLIC_WS_URL="ws://127.0.0.1:8000/api/v1/ws"

# ------------------------------------------------------------------------------
# 💾 APPLICATION LIMITS & SAFEGUARDS
# ------------------------------------------------------------------------------
# The maximum allowed size for source image uploads (in Megabytes).
# Applies to Image-to-Image, Inpainting, and ControlNet source images.
# Default: 20
NEXT_PUBLIC_MAX_UPLOAD_MB=20

# ------------------------------------------------------------------------------
# 🚦 FEATURE FLAGS (For Future Expansion)
# ------------------------------------------------------------------------------
# Set these to 'true' to enable experimental or upcoming UI features.

# Prepares the UI for cloud synchronization of generations and settings.
# Leave 'false' for a pure, secure local experience.
# Default: false
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false

# Prepares the UI for team collaboration features (shared projects, galleries).
# Default: false
NEXT_PUBLIC_ENABLE_TEAMS=false

# Unlocks the advanced Node-Based Workflow Builder tab.
# Default: false
NEXT_PUBLIC_ENABLE_WORKFLOW_BUILDER=false

# ------------------------------------------------------------------------------
# 📊 TELEMETRY & DEBUGGING (Optional)
# ------------------------------------------------------------------------------
# Enable detailed logging in the browser console for React Query and WebSocket events.
# Default: false
NEXT_PUBLIC_DEBUG_MODE=false
